<?xml version="1.0"?>
<robot name="joint_robot">
  <!-- 底座连杆 -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.6 0.4 0.2"/></geometry>
      <material name="gray">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry><box size="0.6 0.4 0.2"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0"
               iyx="0.0" iyy="0.1" iyz="0.0"
               izx="0.0" izy="0.0" izz="0.1"/>
    </inertial>
  </link>

  <!-- 云台连杆（可旋转） -->
  <link name="pan_link">
    <visual>
      <geometry>
        <cylinder radius="0.12" length="0.3"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.12" length="0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0"
               iyx="0.0" iyy="0.01" iyz="0.0"
               izx="0.0" izy="0.0" izz="0.01"/>
    </inertial>
  </link>

  <!-- 旋转关节：底座 -> 云台 -->
  <joint name="base_to_pan" type="revolute">
    <parent link="base_link"/>
    <child link="pan_link"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="1.0" velocity="1.0"/>
  </joint>
</robot>