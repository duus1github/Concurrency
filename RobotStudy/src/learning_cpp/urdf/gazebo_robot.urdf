<?xml version="1.0"?>
<robot name="gazebo_robot">
  <!-- 底盘连杆 -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.6 0.4 0.2"/>
      </geometry>
      <material name="gray">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.6 0.4 0.2"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0"
               iyx="0.0" iyy="0.1" iyz="0.0"
               izx="0.0" izy="0.0" izz="0.1"/>
    </inertial>
    <!-- Gazebo底盘仿真材质 -->
    <gazebo reference="base_link">
      <material>Gray</material>
    </gazebo>
  </link>

  <!-- 云台连杆 -->
  <link name="pan_link">
    <visual>
      <geometry>
        <cylinder radius="0.12" length="0.3"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.12" length="0.3"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0"
               iyx="0.0" iyy="0.01" iyz="0.0"
               izx="0.0" izy="0.0" izz="0.01"/>
    </inertial>
    <gazebo reference="pan_link">
      <material>Blue</material>
    </gazebo>
  </link>

  <!-- 雷达连杆（挂载仿真激光雷达插件） -->
  <link name="laser_link">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.1 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyx="0" iyy="0.001" iyz="0" izx="0" izy="0" izz="0.001"/>
    </inertial>
    <!-- Gazebo激光雷达仿真插件核心配置 -->
    <gazebo reference="laser_link">
      <sensor type="ray" name="laser_scan">
        <pose>0 0 0 0 0 0</pose>
        <ray>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-1.57</min_angle>
              <max_angle>1.57</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.1</min>
            <max>10.0</max>
            <resolution>0.01</resolution>
          </range>
        </ray>
        <plugin name="gazebo_ros_laser" filename="libgazebo_ros_laser.so">
          <frameName>laser_link</frameName>
          <topicName>scan</topicName>
        </plugin>
      </sensor>
    </gazebo>
  </link>

  <!-- 底座-云台 旋转关节 -->
  <joint name="base_to_pan" type="revolute">
    <parent link="base_link"/>
    <child link="pan_link"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="1.0" velocity="1.0"/>
  </joint>

  <!-- 云台-雷达 固定关节 -->
  <joint name="pan_to_laser" type="fixed">
    <parent link="pan_link"/>
    <child link="laser_link"/>
    <origin xyz="0.15 0 0.1" rpy="0 0 0"/>
  </joint>
</robot>